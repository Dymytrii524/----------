@{
    ViewData["Title"] = "Гостева книга";
}

<h4 class="mb-4">Гостева книга</h4>

@if (User.Identity != null && User.Identity.IsAuthenticated)
{
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div id="error-msg" class="alert alert-danger py-2 d-none"></div>
            <form id="messageForm">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <textarea id="messageText" name="messageText" class="form-control"
                              rows="3" placeholder="Ваше повідомлення..."></textarea>
                </div>
                <button type="submit" class="btn btn-dark btn-sm">Додати повідомлення</button>
            </form>
        </div>
    </div>
}
else
{
    <div class="alert alert-secondary">
        <a asp-controller="Account" asp-action="Login">Увійдіть</a>
        або
        <a asp-controller="Account" asp-action="Register">зареєструйтесь</a>,
        щоб залишити повідомлення.
    </div>
}

<div id="messages-container">
    <div class="text-muted">Завантаження...</div>
</div>

@section Scripts {
<script>
    function esc(str) {
        return String(str)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;');
    }

    function renderMessages(messages) {
        var c = document.getElementById('messages-container');
        if (!messages.length) {
            c.innerHTML = '<p class="text-muted">Повідомлень ще немає.</p>';
            return;
        }
        c.innerHTML = messages.map(function (m) {
            return '<div class="card mb-3 shadow-sm">' +
                '<div class="card-header d-flex justify-content-between py-2">' +
                '<strong>' + esc(m.userName) + '</strong>' +
                '<small class="text-muted">' + esc(m.date) + '</small>' +
                '</div>' +
                '<div class="card-body py-2">' + esc(m.text) + '</div>' +
                '</div>';
        }).join('');
    }

    function loadMessages() {
        fetch('/Home/GetMessages')
            .then(function (r) { return r.json(); })
            .then(renderMessages)
            .catch(function () {
                document.getElementById('messages-container').innerHTML =
                    '<div class="alert alert-danger">Помилка завантаження повідомлень.</div>';
            });
    }

    loadMessages();

    var form = document.getElementById('messageForm');
    if (form) {
        form.addEventListener('submit', function (e) {
            e.preventDefault();
            var errDiv = document.getElementById('error-msg');
            errDiv.classList.add('d-none');

            var text  = document.getElementById('messageText').value;
            var token = form.querySelector('input[name="__RequestVerificationToken"]').value;

            fetch('/Home/AddMessage', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'messageText=' + encodeURIComponent(text) +
                      '&__RequestVerificationToken=' + encodeURIComponent(token)
            })
            .then(function (r) { return r.json(); })
            .then(function (data) {
                if (data.success) {
                    document.getElementById('messageText').value = '';
                    loadMessages();
                } else {
                    errDiv.textContent = data.error;
                    errDiv.classList.remove('d-none');
                }
            })
            .catch(function () {
                errDiv.textContent = 'Помилка при відправці повідомлення.';
                errDiv.classList.remove('d-none');
            });
        });
    }
</script>
}
