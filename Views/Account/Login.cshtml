@{
    ViewData["Title"] = "Вхід";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h4 class="card-title mb-4 text-center">Вхід в систему</h4>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger py-2">@ViewBag.Error</div>
                }

                <form method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label" for="Name">Логін</label>
                        <input type="text" id="Name" name="Name" class="form-control" placeholder="Введіть логін" />
                    </div>

                    <div class="mb-4">
                        <label class="form-label" for="Pwd">Пароль</label>
                        <input type="password" id="Pwd" name="Pwd" class="form-control" placeholder="Введіть пароль" />
                    </div>

                    <div class="d-grid mb-3">
                        <button type="submit" class="btn btn-dark">Увійти</button>
                    </div>

                    <div class="text-center small">
                        Немає акаунта? <a asp-controller="Account" asp-action="Register">Зареєструватись</a>
                        &nbsp;|&nbsp;
                        <a asp-controller="Account" asp-action="Guest">Увійти як гість</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
