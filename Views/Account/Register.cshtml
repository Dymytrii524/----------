@model GuestBook.Models.RegisterViewModel
@{
    ViewData["Title"] = "Реєстрація";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h4 class="card-title mb-4 text-center">Реєстрація</h4>

                <form method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Логін</label>
                        <input asp-for="Name" class="form-control" placeholder="Введіть логін" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Pwd" class="form-label">Пароль</label>
                        <input asp-for="Pwd" class="form-control" placeholder="Введіть пароль" />
                        <span asp-validation-for="Pwd" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="PwdConfirm" class="form-label">Підтвердження пароля</label>
                        <input asp-for="PwdConfirm" class="form-control" placeholder="Повторіть пароль" />
                        <span asp-validation-for="PwdConfirm" class="text-danger small"></span>
                    </div>

                    <div class="d-grid mb-3">
                        <button type="submit" class="btn btn-dark">Зареєструватись</button>
                    </div>

                    <div class="text-center small">
                        Вже є акаунт? <a asp-controller="Account" asp-action="Login">Увійти</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
